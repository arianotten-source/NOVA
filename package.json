{
  "name": "nova-assistant",
  "version": "1.0.0",
  "description": "N.O.V.A. - Neural Observation & Voice Assistant",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm run electron:compile && concurrently -k \"vite\" \"node scripts/start-sensor-api.cjs\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:web": "tsc && vite build",
    "vercel-build": "npm run build:web",
    "preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && concurrently -k \"vite\" \"wait-on http://localhost:5175 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.neonpulselabs.nova",
    "productName": "N.O.V.A.",
    "directories": {
      "output": "exports"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "data/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
